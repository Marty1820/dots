// -*- mode: jsonc -*-
{
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.py",
    "hide-empty-text": true,
    "return-type": "json",
    "interval": "once",
    "format": "{}",
    "min-length": 8,
    "max-length": 8,
    "on-click": "ewwii open --toggle weather",
    "on-click-right": "~/.config/waybar/scripts/weather.py",
    "signal": 10
  }
}
