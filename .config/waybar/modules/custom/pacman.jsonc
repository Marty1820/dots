// -*- mode: jsonc -*-
{
  "custom/pacman": {
    "format": "",
    "min-length": 1,
    "max-length": 1,
    "interval": 3600, // every hour
    "exec": "checkupdates | wc -l", // # of updates
    "exec-if": "test $(checkupdates | wc -l) -gt 0", // always run; consider advanced run conditions
    "on-click": "kitty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
    "signal": 8,
    "tooltip-format": "Updates: {} Available",
  },
}
