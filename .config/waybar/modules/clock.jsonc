// -*- mode: jsonc -*-
{
  "clock#time": {
    "format": "{:%H:%M}",
    "min-length": 5,
    "max-length": 5,
    "tooltip-format": "<b>Standard Time</b>: <span text_transform='lowercase'>{:%I:%M %p}</span>"
  },
  "clock#date": {
    "format": "󰃶 {:%b %d}",
    "min-length": 8,
    "max-length": 8,
    "on-click": "ewwii call-fns 'toggle_window(calendar)'",
    "tooltip": false
  }
}
