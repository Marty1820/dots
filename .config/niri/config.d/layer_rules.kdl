//--- Layer Rules ---
layer-rule {
  match namespace="^wallpaper$"
  match namespace="awww-daemon"
  place-within-backdrop true
}

layer-rule {
  match namespace="^notifications$"
  block-out-from "screencast"
}

layer-rule {
  match namespace="^launcher$"

  shadow {
    on
  }

  geometry-corner-radius 12
}
