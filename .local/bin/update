#!/usr/bin/env bash
set -euo pipefail
# pacman -Syu reflector rebuild-detector tldr fwupd udisks2
# systemctl enable --now reflector.timer fwupd-refresh.timer udisks2.service
# fwupdmgr get-updates

# Configuration
INTERACTIVE=${INTERACTIVE:-1} # 1 for prompts. 0 for unnatended
LOG_FILE="$HOME/.local/share/update.log"
CONFIG_LOG_DIR="$(dirname "$LOG_FILE")"

# Ensure log directory exists
mkdir -p "$CONFIG_LOG_DIR"
touch "$LOG_FILE"

# Colors
BOLD="\033[1m"
RESET="\033[0m"
RED="\033[31;1m"
GREEN="\033[32;1m"
YELLOW="\033[33;1m"

# Logging setup
log() {
  local msg cutoff_date tmp_file
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  msg="[$timestamp] $1"

  # Output to terminal with colors
  echo -e "$msg"

  # Writ to file without ANSI codes
  printf '%s\n' "$msg" |
    sed -E 's/\\033\[[0-9;]*m//g; s/\x1b\[[0-9;]*m//g' >>"$LOG_FILE"

  # Log rotation (Keep last 15 days)
  cutoff_date=$(date -d '15 days ago' '+%Y-%m-%d')
  tmp_file="${LOG_FILE}.tmp"

  # Use awk to filer safely
  awk -v cutoff="$cutoff_date" '{gsub(/[\[\]]/, "", $1); if ($1 >= cutoff) print}' "$LOG_FILE" >"$tmp_file"
  mv "$tmp_file" "$LOG_FILE"
}

# Print formatted header
print_header() {
  local msg="$1"
  log "${BOLD}${msg}${RESET}"
  echo ""
}

# Confirmation wrapper
confirm() {
  if [[ $INTERACTIVE -eq 0 ]]; then
    return 1 # Auto-decline in unattended mode
  fi
  read -rp "$1 [y/N]: " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# Package upgrade
pkg_update() {
  print_header "Upgrading Packages"
  local flags=""
  local pm=""

  [[ $INTERACTIVE -eq 0 ]] && flags="--noconfirm"

  if command -v paru &>/dev/null; then
    pm="paru"
    log "Using 'paru' for upgrades."
  elif command -v pacman &>/dev/null; then
    pm="pacman"
    log "Using 'pacman' for upgrades."
  else
    log "${RED}No package manager found (paru or pacman).${RESET}"
    return 1
  fi

  # Run upgrade
  if ! "$pm" -Syu $flags; then
    log "${RED}Package upgrade failed.${RESET}"
    return 1
  fi
}

# Rebuild check
rebuild() {
  print_header "Checking for broken packages"
  if ! command -v checkrebuild &>/dev/null; then
    log "checkrebuild not installed. Skipping"
    return 0
  fi

  if ! checkrebuild -v; then
    log "${YELLOW}Rebuild needed for above packages.${RESET}"
    if [[ $INTERACTIVE -eq 1 ]]; then
      read -rp "Press enter to continue..."
    fi
  else
    log "No rebuilds needed"
  fi
}

# TLDR cache update
tldr_cache() {
  if ! command -v tldr &>/dev/null; then
    log "tldr not installed. Skipping."
    return 0
  fi

  print_header "Updating TLDR-pages"
  if ! tldr --update_cache; then
    log "${RED}Failed to update tldr cache.${RESET}"
  fi
}

# Firmware update
fwupd() {
  if ! command -v fwupdmgr &>/dev/null; then
    log "fwupdmgr not installed. Skipping."
    return 0
  fi

  print_header "Firmware check/update"
  if ! fwupdmgr update; then
    log "${RED}Firmware update failed or cancelled.${RESET}"
  fi
}

# CPU vulnerability check
cpu_vulns() {
  print_header "Checking CPU vulnerabilities"

  # Prefer /sys method over lscpu for accuracy
  local vuln_found=0

  if [[ -d "/sys/devices/system/cpu/vulnerabilities" ]]; then
    for v in /sys/devices/system/cpu/vulnerabilities/*; do
      if grep -qi "vulnerable" "$v"; then
        local name=$(basename "$v")
        local status=$(cat "$v")
        log "${RED}WARNING: CPU vulnerability '$name' detected: $status${RESET}"
        vuln_found=1
      fi
    done
  fi

  if [[ $vuln_found -eq 1 ]]; then
    echo "Run 'lscpu' or check '/sys/devices/system/cpu/vulnerabilities/' for details."
    if [[ $INTERACTIVE -eq 1 ]]; then
      read -rp "Press enter to continue..."
    fi
    return 1
  else
    log "${GREEN}No known CPU vulnerabilities detected.${RESET}"
  fi
}

# Kernel check and reboot
kern_chk() {
  local current_pkg running_ver current_base running_base
  print_header "Checking for new Kernel"

  # Determine installed kernel package dynamically
  current_pkg=$(pacman -Q linux 2>/dev/null | awk '{print $2}') || {
    log "${YELLOW}Could not determine installed kernel package (linux). Assuming manual management.${RESET}"
    orphan_pkgs
    return 0
  }

  running_ver=$(uname -r)

  # Extract major.minor.patch for comparison
  current_base=$(echo "$current_pkg" | grep -oE '^[0-9]+\.[0-9]+(\.[0-9]+)?')
  running_base=$(echo "$running_ver" | grep -oE '^[0-9]+\.[0-9]+(\.[0-9]+)?')

  if [[ -z "$current_base" || -z "$running_base" ]]; then
    log "${YELLOW}Warning: Could not parse version strings. Falling back to string comparison.${RESET}"
    current_base="$current_pkg"
    running_base="$running_ver"
  fi

  log "Installed: $current_pkg (Parsed: $current_base)"
  log "Running:   $running_ver (Parsed: $running_base)"

  if [[ "$current_base" == "$running_base" ]]; then
    log "Kernel matches running version. No reboot needed."
  else
    log "${RED}Newer kernel ($current_pkg) installed but running ($running_ver). Reboot required.${RESET}"

    if [[ $INTERACTIVE -eq 1 ]]; then
      if confirm "Reboot now?"; then
        log "${GREEN}Rebooting...${RESET}"
        reboot
        exit 0
      else
        log "${YELLOW}Reboot deferred by user.${RESET}"
      fi
    else
      log "${YELLOW}Unattended mode: Reboot deferred. Please reboot manually.${RESET}"
    fi
  fi

  orphan_pkgs
}

# Orphaned packages
orphan_pkgs() {
  print_header "Orphaned Packages"

  local orphans
  orphans=$(pacman -Qdtq 2>/dev/null || true)

  if [[ -z "$orphans" ]]; then
    log "No orphaned packages found."
    return 0
  fi

  log "${YELLOW}Found orphaned packages:${RESET}"
  echo "$orphans"

  if [[ $INTERACTIVE -eq 1 ]]; then
    if confirm "Remove them?"; then
      log "Removing orphans..."
      echo "$orphans" | sudo xargs pacman -Rns --noconfirm --needed
    fi
  else
    log "${YELLOW}Unattended mode: Opheran removal skipped. Manual review recommended.${RESET}"
  fi
}

# Waybar reload
waybar_reload() {
  if pgrep -x waybar >/dev/null; then
    pkill -SIGRTMIN+8 waybar
    log "${GREEN}Waybar reload signal sent.${RESET}"
  else
    log "${YELLOW}Waybar not running. Skipping reload.${RESET}"
  fi
}

# Main
main() {
  pkg_update || {
    log "${RED}Update aborted due to package manager failure.${RESET}"
    exit 1
  }
  rebuild
  tldr_cache
  fwupd
  cpu_vulns
  kern_chk
  waybar_reload

  log "${GREEN}Update script completed.${RESET}"
}

main
