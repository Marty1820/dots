#!/usr/bin/env bash
set -euo pipefail

# Configuration
INTERACTIVE=${INTERACTIVE:-1} # 1 for prompts. 0 for unnatended
LOG_FILE="$HOME/.local/share/update.log"

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")"

# Colors
BOLD="\033[1m"
RESET="\033[0m"
RED="\033[31;1m"
GREEN="\033[32;1m"
YELLOW="\033[33;1m"

# Logging setup
log() {
  local msg cutoff_date tmp_file
  msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"

  # Calculate cutoff date
  cutoff_date=$(date -d '15 days ago' '+%Y-%m-%d')

  # Keep only lines from the cutoff date
  tmp_file="${LOG_FILE}.tmp"
  awk -v cutoff="$cutoff_date" '{gsub(/[\[\]]/, "", $1); if ($1 >= cutoff) print}' "$LOG_FILE" >"$tmp_file"
  mv "$tmp_file" "$LOG_FILE"

  # Output to terminal with colors
  echo -e "$msg"

  # Write to file without ANSI codes
  printf '%s\n' "$msg" |
    sed -E 's/\\033\[[0-9;]*m//g; s/\x1b\[[0-9;]*m//g' >>"$LOG_FILE"
}

# Print formatted header
print_header() {
  local msg="$1"
  log "${BOLD}${msg}${RESET}"
  echo ""
}

# Confirmation wrapper
confirm() {
  if [[ $INTERACTIVE -eq 0 ]]; then
    return 1 # Auto-decline in unattended mode
  fi
  read -rp "$1 [y/N]: " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# Update mirrors if older than 7 days
check_mirrorlist() {
  local mirrorlist="/etc/pacman.d/mirrorlist"

  if [[ ! -f "$mirrorlist" ]]; then
    log "Mirrorlist not found. Skipping"
    return 0
  fi

  local age_seconds=$(($(date +%s) - $(stat -c %Y "$mirrorlist")))
  local max_age=604800 # 7 days

  if [[ $age_seconds -gt $max_age ]]; then
    print_header "Updating mirrorlist with reflector"

    if ! systemctl is-active --quiet reflector.service 2>/dev/null; then
      systemctl start reflector.service || {
        log "${RED}Failed to start reflector.service${RESET}"
        return 1
      }

      # Wait for completion
      while systemctl is-active --quiet reflector.service; do
        sleep 1
      done
      log "Reflector service completed."
    else
      log "Reflector service already active."
    fi
  else
    log "Mirrorlist is fresh (${age_seconds}s old)."
  fi
}

# Package upgrade
pkg_update() {
  print_header "Upgrading Packages"
  local flags=""

  [[ $INTERACTIVE -eq 0 ]] && flags="--noconfirm"

  if command -v paru &>/dev/null; then
    log "Using 'paru' for upgrades."
    if ! paru -Syu $flags; then
      log "${RED}Paru upgrade failed.${RESET}"
      return 1
    fi
  elif command -v pacman &>/dev/null; then
    log "Using 'pacman' for upgrades."
    if ! sudo pacman -Syu $flags; then
      log "${RED}Pacman upgrade failed.${RESET}"
      return 1
    fi
  else
    log "${RED}No package manager found (paru or pacman).${RESET}"
    return 1
  fi
}

# Rebuild check
# pacman -S rebuild-checker
rebuild() {
  print_header "Checking for broken packages"

  if ! command -v checkrebuild &>/dev/null; then
    log "checkrebuild not installed. Skipping"
    return 0
  fi

  if ! checkrebuild -v; then
    log "${YELLOW}Rebuild needed for above packages.${RESET}"
    if [[ $INTERACTIVE -eq 1 ]]; then
      read -rp "Press enter to continue..."
    fi
  else
    log "No rebuilds needed"
  fi
}

# TLDR cache update
# pacman -S tldr
tldr_cache() {
  if ! command -v tldr &>/dev/null; then
    log "tldr not installed. Skipping."
    return 0
  fi

  print_header "Updating TLDR-pages"

  if ! tldr --update_cache; then
    log "${RED}Failed to update tldr cache.${RESET}"
  fi
}

# Firmware update
# pacman -S fwupd udisks2
# systemctl enable --now fwupd-refresh.timer
fwupd() {
  if ! command -v fwupdmgr &>/dev/null; then
    log "fwupdmgr not installed. Skipping."
    return 0
  fi

  print_header "Firmware check/update"

  if ! fwupdmgr update; then
    log "${RED}Firmware update failed or cancelled.${RESET}"
  fi
}

# CPU vulnerability check
cpu_vulns() {
  print_header "Checking CPU vulnerabilities"

  if ! command -v lscpu &>/dev/null; then
    log "lscpu not found. Skipping."
    return 0
  fi

  local vuln_output
  vuln_output=$(lscpu | grep -i "Vulnerability:.*Vulnerable" || true)

  if [[ -n "$vuln_output" ]]; then
    log "${RED}WARNING: CPU vulnerabilities detected!${RESET}"
    echo "$vuln_output"
    echo "Run 'lscpu' manually for details."

    if [[ $INTERACTIVE -eq 1 ]]; then
      read -rp "Press enter to continue..."
    fi
    return 1
  else
    log "${GREEN}No known CPU vulnerabilities detected."
  fi
}

# Kernel check and reboot
kern_chk() {
  local current_pkg running_ver current_base running_base
  print_header "Checking for new Kernel"

  current_pkg=$(pacman -Q linux 2>/dev/null | awk '{print $2}')

  if [[ -z "$current_pkg" ]]; then
    log "${RED}Could not determine installed kernel package. Skipping."
    orphan_pkgs
    return 0
  fi

  running_ver=$(uname -r)

  # Extract the numeric version (e.g., 6.19.10)
  # BETTER METHOD: Use grep to extract the leading version pattern
  current_base=$(echo "$current_pkg" | grep -oE '^[0-9]+\.[0-9]+(\.[0-9]+)?')
  running_base=$(echo "$running_ver" | grep -oE '^[0-9]+\.[0-9]+(\.[0-9]+)?')

  if [[ -z "$current_base" || -z "$running_base" ]]; then
    log "${YELLOW}Warning: Could not parse version strings. Falling back to string comparison."
    current_base="$current_pkg"
    running_base="$running_ver"
  fi

  log "Installed: $current_pkg (Parsed: $current_base)"
  log "Running:   $running_ver (Parsed: $running_base)"

  if [[ "$current_base" == "$running_base" ]]; then
    log "Current kernel matches installed package. No reboot needed."
  else
    log "${RED}Newer kernel ($current_pkg) installed but running ($running_ver). Reboot required.${RESET}"

    if [[ $INTERACTIVE -eq 1 ]]; then
      if confirm "Reboot now?"; then
        log "${GREEN}Rebooting..."
        reboot
        exit 0
      else
        log "${YELLOW}Reboot deferred by user."
      fi
    else
      log "${YELLOW}Unattended mode: Reboot deferred. Please reboot manually."
    fi
  fi

  orphan_pkgs
}

# Orphaned packages
orphan_pkgs() {
  print_header "Orphaned Packages"

  local orphans
  orphans=$(pacman -Qdtq 2>/dev/null || true)

  if [[ -z "$orphans" ]]; then
    log "No orphaned packages found."
  else
    log "${YELLOW}Found orphaned packages:${RESET}"
    echo "$orphans"
    if [[ $INTERACTIVE -eq 1 ]]; then
      read -rp "Remove them? [y/N]: " ans
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        log "Removing orphans..."
        sudo pacman -Rns $(pacman -Qdtq)
      fi
    fi
  fi
}

# Waybar reload
waybar_reload() {
  if pgrep -x waybar >/dev/null; then
    pkill -SIGRTMIN+8 waybar || log "${GREEN}Waybar reload signal sent"
  else
    log "${YELLOW}Waybar not running. Skipping reload"
  fi
}

# ---------------------
# Main Execution
# ---------------------
main() {
  check_mirrorlist
  pkg_update
  rebuild
  tldr_cache
  fwupd
  cpu_vulns
  kern_chk
  waybar_reload

  log "${GREEN}Update script completed."
}

main
